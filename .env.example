# ── Client (exposed to the browser — must be prefixed with VITE_) ────────────
# URL of your hosted PocketBase instance (PocketBase Cloud, Pockethost, etc.)
VITE_POCKETBASE_URL=https://your-instance.pocketbasecloud.com
# VAPID public key (from: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
# Shared secret the app sends as x-push-secret to authorize push sends.
# NOTE: bundled into the client — obfuscation only, fine for a trusted group.
# The /api/send-push function reads the same variable via process.env.
VITE_PUSH_SECRET=some-long-random-string

# ── Server-only (used by the /api/send-push Vercel function — never VITE_) ───
POCKETBASE_URL=https://your-instance.pocketbasecloud.com
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=your-pocketbase-superuser-password
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
